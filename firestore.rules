rules_version = '2';

// Regras que espelham o comportamento atual do app NES Canvas.
// - settings/main: lido antes do login (o app trata-o como público).
// - users: lido antes do login no fluxo de registo (procura por email).
// - restantes coleções: apenas para utilizadores autenticados.
service cloud.firestore {
  match /databases/{database}/documents {

    // Definições da app (adminPin, tabletMode). Leitura pública; escrita autenticada.
    match /settings/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Perfis de contas. Leitura pública (necessária para o registo por email);
    // escrita apenas autenticada.
    match /users/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Dados operacionais: só utilizadores autenticados.
    match /teachers/{docId}      { allow read, write: if request.auth != null; }
    match /classes/{docId}       { allow read, write: if request.auth != null; }
    match /lessonPlans/{docId}   { allow read, write: if request.auth != null; }
    match /logs/{docId}          { allow read, write: if request.auth != null; }
    match /substitutions/{docId}     { allow read, write: if request.auth != null; }
    match /examRequests/{docId}      { allow read, write: if request.auth != null; }
    match /recoveryRequests/{docId}  { allow read, write: if request.auth != null; }
  }
}
